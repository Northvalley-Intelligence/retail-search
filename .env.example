CRANFIELD_INDEX=cranfield-v0
ARCHITECTURE_VERSION=v0-cranfield-opensearch-baseline

OPENSEARCH_URL=https://your-opensearch-provider.example:443
OPENSEARCH_USERNAME=retail_search_runtime
OPENSEARCH_PASSWORD=replace-with-runtime-secret

# Optional alternative when the OpenSearch provider supports API-key auth.
# OPENSEARCH_API_KEY=replace-with-runtime-api-key

# Local ingestion credentials. Do not expose these to the public Worker.
OPENSEARCH_INDEXER_USERNAME=retail_search_indexer
OPENSEARCH_INDEXER_PASSWORD=replace-with-indexer-secret

CLOUDFLARE_ACCOUNT_ID=replace-with-account-id
CLOUDFLARE_API_TOKEN=replace-with-workers-deploy-token
